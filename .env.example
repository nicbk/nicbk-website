# Template for the git-ignored .env file. Every variable the app reads is
# declared in src/env.ts (the Zod schema) and documented here.
#
# No variable is required yet — both of these have defaults. Later features
# (authentication, lit-tracker) add their required variables here.

# Runtime environment: development | production | test. Default: development.
#NODE_ENV=development

# Port the app server listens on. Default: 3000.
#PORT=3000
