{
  "$schema": "https://biomejs.dev/schemas/2.5.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": ["**", "!**/routeTree.gen.ts"]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "asNeeded"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "preset": "recommended",
      "nursery": {
        "useReactFunctionComponentDefinition": {
          "level": "error",
          "options": {
            "namedComponents": "functionDeclaration"
          }
        }
      },
      "style": {
        "noDefaultExport": "error",
        "useImportType": {
          "level": "error",
          "options": {
            "style": "inlineType"
          }
        },
        "useFilenamingConvention": {
          "level": "error",
          "options": {
            "filenameCases": ["kebab-case"]
          }
        }
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": [
              ":NODE:",
              [":PACKAGE:", "!~/"],
              "~/**",
              [":PATH:", "!:STYLE:"],
              ":STYLE:"
            ]
          }
        }
      }
    }
  },
  "overrides": [
    {
      "includes": [
        "vite.config.ts",
        "vitest.config.ts",
        "playwright.config.ts",
        "src/server.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noDefaultExport": "off"
          }
        }
      }
    },
    {
      "includes": ["src/routes/**"],
      "linter": {
        "rules": {
          "style": {
            "useFilenamingConvention": {
              "level": "error",
              "options": {
                "filenameCases": ["kebab-case"],
                "requireAscii": false
              }
            }
          }
        }
      }
    }
  ]
}
