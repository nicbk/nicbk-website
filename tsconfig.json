{
  "compilerOptions": {
    // Language/output targets — TanStack Start's documented baseline.
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["vite/client"],

    // Vite owns emit; tsc is typecheck-only (`npm run typecheck`).
    "noEmit": true,
    "skipLibCheck": true,

    // Strictness: `strict` plus the agreed low-friction extras.
    // `exactOptionalPropertyTypes` is deliberately NOT enabled — see
    // research/coding-conventions/typescript-conventions.md.
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noPropertyAccessFromIndexSignature": true,

    // Keeps type-only imports explicit (`import { type Foo }`), pairing
    // with Biome's `useImportType` inlineType style.
    "verbatimModuleSyntax": true,

    // `~/` alias for cross-cutting imports (relative imports stay relative
    // for nearby/colocated code) — see
    // research/coding-conventions/import-conventions.md.
    "paths": {
      "~/*": ["./src/*"]
    },

    // Overlays generated/src onto src so *.module.css imports resolve to
    // the exact-key .d.ts files cmk generates (see cmkOptions below).
    "rootDirs": ["src", "generated/src"]
  },
  "include": ["src", "vite.config.ts", "vitest.config.ts", "vitest.setup.ts"],
  // Generates exact-key .d.ts files for *.module.css (via `npx cmk`, wired
  // into the typecheck script), so the decided dot-notation access to CSS
  // Modules composes with noPropertyAccessFromIndexSignature — and class
  // name typos fail the typecheck. Resolution recorded in
  // research/coding-conventions/typescript-conventions.md.
  "cmkOptions": {
    "enabled": true
  }
}
